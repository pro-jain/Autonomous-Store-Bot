                  </bind_material>
                </instance_geometry>
              </node>
            </node>
          </node>
        </node>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Sketchfab_Scene" />
  </scene>
</COLLADA>
